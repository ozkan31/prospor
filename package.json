{
  "name": "prospor-storefront",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "tr:check": "node scripts/check-tr-text.mjs",
    "predev": "npm run tr:check",
    "predev:server": "npm run tr:check",
    "prebuild": "npm run tr:check",
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "dev:host": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "node server/scripts/initDb.js",
    "db:seed": "node server/scripts/seedProducts.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^8.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "vite": "^5.4.11"
  }
}
